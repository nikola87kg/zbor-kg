    "@angular/cdk": "^22.0.3",
    "@angular/common": "^22.0.3",
    "@angular/compiler": "^22.0.3",
    "@angular/core": "^22.0.3",
    "@angular/forms": "^22.0.3",
    "@angular/material": "^22.0.3",
    "@angular/platform-browser": "^22.0.3",
    "@angular/platform-server": "^22.0.3",
    "@angular/router": "^22.0.3",
    "@angular/service-worker": "^22.0.3",
    "@angular/ssr": "^22.0.3",
    "express": "^5.1.0",
    "firebase": "^12.14.0",
    "ngx-quill": "^30.1.3",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.3",
