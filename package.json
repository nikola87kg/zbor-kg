{
  "name": "zbor",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "cross-env NG_HMR_TEMPLATES=1 NG_ALLOWED_HOSTS=* ng serve --host 0.0.0.0 --port 4201 --allowed-hosts=all",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
