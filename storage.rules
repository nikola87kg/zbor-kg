rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /news/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /affairs/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /actions/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /users/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
